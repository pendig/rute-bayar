---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { changelogEntries } from "../../data/changelog";
---

<BaseLayout
  title="Rute Bayar Changelog"
  description="Release history for Rute Bayar, from early alpha builds to the stable CLI payment router foundation."
  lang="en"
  alternatePath="/changelog/"
>
  <section class="container page-title changelog-title">
    <p class="eyebrow">Changelog</p>
    <h1>Rute Bayar release history.</h1>
    <p>
      Important changes across providers, webhooks, forwarding, CI, release automation, and operational readiness.
    </p>
  </section>

  <section class="container changelog-list">
    {changelogEntries.map((entry) => (
      <article>
        <div class="release-meta">
          <span>{entry.version}</span>
          <time datetime={entry.date}>{entry.date}</time>
          <strong>{entry.tag}</strong>
        </div>
        <div>
          <p>{entry.summary}</p>
          <ul>
            {entry.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>

<style>
  .changelog-title {
    padding-bottom: 34px;
  }

  .changelog-list {
    display: grid;
    gap: 0;
    padding-bottom: 96px;
  }

  .changelog-list article {
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: minmax(180px, 0.45fr) minmax(0, 1fr);
    gap: 34px;
    padding: 30px 0;
  }

  .release-meta {
    display: grid;
    gap: 8px;
    align-content: start;
  }

  .release-meta span {
    color: var(--ink);
    font-family: "IBM Plex Mono", monospace;
    font-size: 1.2rem;
    font-weight: 800;
  }

  .release-meta time {
    color: var(--ink-muted);
  }

  .release-meta strong {
    width: fit-content;
    border: 1px solid var(--line);
    padding: 6px 8px;
    background: rgba(255, 255, 255, 0.42);
    color: var(--rail-dark);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .changelog-list p {
    margin: 0 0 14px;
    color: var(--ink-muted);
    font-size: 1.06rem;
    line-height: 1.7;
  }

  .changelog-list ul {
    margin: 0;
    padding-left: 20px;
    color: var(--ink);
    line-height: 1.65;
  }

  .changelog-list li + li {
    margin-top: 8px;
  }

  @media (max-width: 760px) {
    .changelog-list article {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
